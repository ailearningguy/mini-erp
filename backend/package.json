{
  "name": "@erp/backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc",
    "start": "node dist/main.js",
    "lint": "eslint src/ --ext .ts",
    "lint:spec": "swagger-cli validate specs/openapi.yaml",
    "lint:migration": "tsx scripts/lint-migrations.ts",
    "lint:arch": "tsx scripts/lint-arch.ts",
    "validate:runtime": "tsx scripts/validate-runtime.ts",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "migrate": "drizzle-kit migrate",
    "migrate:generate": "drizzle-kit generate",
    "migrate:rollback": "drizzle-kit rollback",
    "seed": "tsx scripts/seed.ts",
    "outbox-worker": "tsx src/core/outbox/outbox-worker.entry.ts"
  },
  "dependencies": {
    "amqplib": "^0.10.4",
    "bullmq": "^5.34.0",
    "drizzle-orm": "^0.45.2",
    "express": "^4.21.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.0",
    "jsonwebtoken": "^9.0.3",
    "pino": "^9.5.0",
    "prom-client": "^15.1.0",
    "semver": "^7.7.4",
    "uuid": "^10.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@jest/globals": "^30.3.0",
    "@types/amqplib": "^0.10.5",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "@types/semver": "^7.7.1",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "drizzle-kit": "^0.28.0",
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "pg": "^8.13.0",
    "prettier": "^3.4.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.58.0"
  }
}
